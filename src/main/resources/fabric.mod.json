{
	"schemaVersion": 1,
	"id": "${mod_id}",
	"version": "${mod_version}",
	"name": "${mod_name}",
	"description": "${mod_description}",
	"authors": [
		"Tomeko"
	],
	"contact": {
		"homepage": "https://modrinth.com/mod/chatblock",
		"sources": "https://github.com/TomekoYT/ChatBlock",
		"issues": "https://github.com/TomekoYT/ChatBlock/issues"
	},
	"license": "CC0-1.0",
	"icon": "assets/chatblock/icon.png",
	"environment": "client",
	"entrypoints": {
		"client": [
			"tomeko.chatblock.ChatBlock"
		],
		"modmenu": [
			"tomeko.chatblock.config.ModMenuIntegration"
		]
	},
	"depends": {
		"java": ">=21",
		"minecraft": "~${minecraft_version}",
		"fabricloader": ">=${fabric_loader_version}",
		"fabric-api": ">=${fabric_api_version}",

		"yet_another_config_lib_v3": ">=${yacl_version}",
		"modmenu": ">=${mod_menu_version}"
	},
	"custom": {
		"youtube": "https://www.youtube.com/@TomekoYT",
		"modmenu": {
			"links": {
				"modmenu.discord": "https://discord.com/invite/FfzrbycDws",
				"modmenu.modrinth": "https://modrinth.com/mod/chatblock"
			},
			"update_checker": true
		}
